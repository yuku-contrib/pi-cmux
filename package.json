{
  "name": "pi-cmux",
  "version": "0.1.12",
  "description": "Pi package with cmux-powered terminal integrations",
  "author": "Javi Molina",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent",
    "cmux",
    "terminal",
    "notifications"
  ],
  "homepage": "https://github.com/javiermolinar/pi-cmux#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/javiermolinar/pi-cmux.git"
  },
  "bugs": {
    "url": "https://github.com/javiermolinar/pi-cmux/issues"
  },
  "bin": {
    "pi-cmux": "install.mjs"
  },
  "scripts": {
    "typecheck": "tsc --noEmit --module NodeNext --moduleResolution NodeNext --target ES2022 --allowImportingTsExtensions --skipLibCheck --strict extensions/*.ts",
    "pack:check": "npm pack --dry-run"
  },
  "files": [
    "extensions/",
    "docs/",
    "install.mjs",
    "README.md",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "pi": {
    "extensions": [
      "./extensions/index.ts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "0.75.5",
    "typescript": "5.9.3"
  }
}
